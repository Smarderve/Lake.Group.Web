{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/fuel.html", "destination": "/lake-oil.html", "permanent": true },
    { "source": "/lpg.html", "destination": "/lake-gas.html", "permanent": true },
    { "source": "/lubricants.html", "destination": "/lake-lubes.html", "permanent": true },
    { "source": "/steel.html", "destination": "/lake-steel.html", "permanent": true },
    { "source": "/concrete.html", "destination": "/lake-premix-cement.html", "permanent": true },
    { "source": "/logistics.html", "destination": "/lake-trans.html", "permanent": true },
    { "source": "/container-services.html", "destination": "/aficd.html", "permanent": true },
    { "source": "/leadership-dileep.html", "destination": "/leadership-dileep-kumar.html", "permanent": true },
    { "source": "/leadership-sibtian-ansari.html", "destination": "/leadership-dileep-kumar.html", "permanent": true },
    { "source": "/leadership-vivek-choudhary.html", "destination": "/leadership-sridhar-mani.html", "permanent": true },
    { "source": "/leadership-bhaskar-shetty.html", "destination": "/leadership-mohammed-khalid.html", "permanent": true },
    { "source": "/leadership-pankaj-kumar.html", "destination": "/leadership-bibhuti-singh.html", "permanent": true }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(tokens|theme|flagship|skeleton|pwa|site|motion|flagship-motion)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }
      ]
    },
    {
      "source": "/assets/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }
      ]
    }
  ]
}
